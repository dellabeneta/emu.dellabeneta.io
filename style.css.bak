/* === RESET & BASE === */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:        #080c10;
  --bg2:       #0d1117;
  --bg3:       #111820;
  --border:    #1e3a2e;
  --border2:   #2a5040;
  --green:     #00ff88;
  --green2:    #00cc66;
  --green3:    #008844;
  --amber:     #ffaa00;
  --amber2:    #cc8800;
  --cyan:      #00eeff;
  --red:       #ff3344;
  --text:      #c8f0d8;
  --text2:     #7ab890;
  --text3:     #3a6648;
  --card-bg:   #0d1a14;
  --card-bdr:  #1a3326;
  --font-mono: 'Share Tech Mono', monospace;
  --font-disp: 'Bebas Neue', sans-serif;
  --font-crt:  'VT323', monospace;
  --glow:      0 0 8px #00ff8866, 0 0 20px #00ff8833;
  --glow-amb:  0 0 8px #ffaa0066, 0 0 20px #ffaa0033;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-mono);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* === OVERLAY EFFECTS === */
.scanlines {
  pointer-events: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: repeating-linear-gradient(
    to bottom,
    transparent 0px,
    transparent 2px,
    rgba(0,0,0,0.08) 2px,
    rgba(0,0,0,0.08) 4px
  );
}

.noise {
  pointer-events: none;
  position: fixed;
  inset: 0;
  z-index: 9998;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 128px 128px;
}

/* === HEADER === */
header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(to bottom, #060a0e 80%, transparent);
  padding: 1.25rem 2rem 0;
}

.header-inner {
  display: flex;
  align-items: flex-end;
  gap: 1.5rem;
  flex-wrap: wrap;
  max-width: calc(1400px - 4rem);
  margin: 0 auto;
}

.logo {
  font-family: var(--font-disp);
  font-size: 4.8rem;
  letter-spacing: 0.06em;
  color: var(--green);
  text-shadow: var(--glow);
  line-height: 0.8;
}

.logo-bracket { color: var(--text3); }
.logo-accent  { color: var(--amber); text-shadow: var(--glow-amb); }

.header-sub {
  font-size: 0.9rem;
  color: var(--text3);
  letter-spacing: 0.12em;
  margin-bottom: 5px;
  
  /* Controle a distância do logotipo aqui! Aumente ou diminua este valor (ex: 1rem, 3rem, 50px) */
  margin-left: 2rem;
  
  /* Empurra a chavinha PT/US lá para o lado direito sozinho */
  margin-right: auto;
}

.stats-highlight {
  color: var(--green);
  text-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
  font-weight: bold;
}

.header-line {
  margin-top: 0.75rem;
  height: 1px;
  background: linear-gradient(to right, var(--green3), var(--border), transparent);
}

/* === LANGUAGE TOGGLE === */
.lang-toggle {
  display: flex;
  gap: 4px;
}

.lang-btn {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  letter-spacing: 0.05em;
  padding: 4px 10px;
  background: transparent;
  border: 1px solid var(--border2);
  color: var(--text2);
  cursor: pointer;
  transition: all 0.15s;
  clip-path: polygon(4px 0%, 100% 0%, calc(100% - 4px) 100%, 0% 100%);
}

.lang-btn:hover {
  border-color: var(--green);
  color: var(--green);
  background: rgba(0,255,136,0.05);
}

.lang-btn.active {
  border-color: var(--green);
  color: var(--bg);
  background: var(--green);
}

/* === MAIN === */
main {
  padding: 1rem 2rem 4rem;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* === CONTROLS === */
.controls {
  display: flex;
  gap: 2rem;
  align-items: flex-end;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.controls > .filter-group:last-child {
  margin-left: auto;
}

.filter-group label {
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  color: var(--text3);
}

.btn-group {
  display: flex;
  gap: 4px;
}

.filter-btn {
  font-family: var(--font-mono);
  font-size: 1rem;
  letter-spacing: 0.1em;
  padding: 5px 14px;
  background: transparent;
  border: 1px solid var(--border2);
  color: var(--text2);
  cursor: pointer;
  transition: all 0.15s;
  clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
}

.filter-btn:hover {
  border-color: var(--green);
  color: var(--green);
  background: rgba(0,255,136,0.05);
}

.filter-btn.active {
  border-color: var(--green);
  color: var(--bg);
  background: var(--green);
  text-shadow: none;
}

.search-wrap, .game-search-box {
  display: flex;
  align-items: center;
  border: 1px solid var(--border2);
  background: var(--bg2);
  padding: 0 10px;
  gap: 8px;
  transition: border-color 0.15s;
  height: 30px;
}

.search-wrap {
  width: 350px;
}

.game-search-box {
  width: 100%;
}

.search-wrap:focus-within, .game-search-box:focus-within { 
  border-color: var(--green); 
}

.search-icon { 
  color: var(--green); 
  font-size: 1.1rem; 
  opacity: 0.8;
}

#search, #game-search {
  font-family: var(--font-mono);
  font-size: 0.90rem;
  letter-spacing: 0.05em;
  background: transparent;
  border: none;
  outline: none;
  color: var(--text);
  width: 100%;
  padding: 0;
}

#search::placeholder, #game-search::placeholder {
  color: var(--text3);
  opacity: 0.7;
}



/* === CAROUSEL === */
.carousel-section {
  position: relative;
  margin-bottom: 1rem;
}

.carousel-container {
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--bg2);
  padding: 1.5rem 0;
}

.carousel-track {
  display: flex;
  gap: 16px;
  padding: 0;
  transition: transform 0.4s cubic-bezier(.4,0,.2,1);
  will-change: transform;
}

/* === CAROUSEL CARD === */
.c-card {
  flex: 0 0 220px;
  background: var(--card-bg);
  border: 1px solid var(--card-bdr);
  padding: 1rem;
  cursor: pointer;
  transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  position: relative;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  height: 245px;
}

.c-card::before {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 12px; height: 12px;
  border-top: 1px solid var(--green3);
  border-right: 1px solid var(--green3);
}

.c-card:hover {
  border-color: var(--green);
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,255,136,0.15);
}

.c-card.active {
  border-color: var(--amber);
  box-shadow: 0 0 16px rgba(255,170,0,0.25);
}

.c-card.active::before {
  border-color: var(--amber);
}

.c-card.hidden { display: none; }

.c-img-wrap {
  width: 120px;
  height: 120px;
  border: 1px solid var(--border);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #060c08;
  position: relative;
}

/* --- ESTILO DE IMAGEM ATUALIZADO --- */
.c-img-wrap img, .detail-img img, .g-thumb img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  mix-blend-mode: lighten;
  filter: grayscale(0.8) brightness(1.1) contrast(1.2);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.c-card:hover .c-img-wrap img,
.g-card:hover .g-thumb img {
  filter: grayscale(0) brightness(1.4) drop-shadow(0 0 8px var(--green));
}

.c-abbr {
  font-family: var(--font-crt);
  font-size: 2rem;
  color: var(--green);
  text-shadow: var(--glow);
  line-height: 1;
}

.c-name {
  font-size: 0.9rem;
  letter-spacing: 0.06em;
  color: var(--text);
  text-align: center;
  line-height: 1.4;
}

.c-era {
  font-size: 0.85rem;
  color: var(--text3);
  letter-spacing: 0.1em;
}

/* === NAV BUTTONS === */
.nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: var(--bg3);
  border: 1px solid var(--border2);
  color: var(--green);
  font-size: 1.3rem;
  width: 38px;
  height: 46px;
  cursor: pointer;
  z-index: 10;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn:hover { background: var(--green); color: var(--bg); border-color: var(--green); }
.nav-btn:disabled { opacity: 0.2; cursor: default; }
.nav-left  { left: -64px; }
.nav-right { right: -64px; }


/* === DETAIL PANEL === */
.detail-panel {
  border: 1px solid var(--border);
  background: var(--bg2);
  margin-bottom: 2.5rem;
  margin-top: 0.5rem;
  min-height: 120px;
  position: relative;
  overflow: hidden;
}

.detail-panel::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--green3), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.detail-panel.loaded::after { opacity: 1; }

.detail-inner {
  padding: 1.5rem;
  display: grid;
  grid-template-columns: 1fr 420px;
  align-items: flex-start;
  gap: 2rem;
  height: 330px; /* Aumentado um pouco para caber melhor a lista */
}

.detail-placeholder {
  grid-column: 1 / -1; /* Ocupa as 3 colunas para ter espaço total */
  font-size: 1.2rem;
  color: var(--text3);
  letter-spacing: 0.12em;
  width: 100%;
  height: 100%;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}



.detail-img {
  width: 140px;
  height: 140px;
  border: 1px solid var(--border2);
  background: #060c08;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.detail-img img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.detail-info {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-left: 0.5rem;
}

/* === GAME LIST SECTION === */
.detail-games {
  display: flex;
  flex-direction: column;
  height: 100%;
  border-left: 1px solid var(--border2);
  padding: 0 8px 0 39px;
  overflow: hidden;
}

.games-header {
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  color: var(--green3);
  margin-bottom: 0.75rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.game-search-box {
  margin-bottom: 0.75rem;
}

.game-search-box input {
  background: none;
  border: none;
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 0.9rem;
  width: 100%;
  outline: none;
}

.game-search-box input::placeholder {
  color: var(--text3);
}

.game-list {
  flex: 1;
  overflow-y: auto;
  padding-right: 0.5rem;
}

/* Scrollbar custom para a lista de jogos */

.game-item {
  padding: 0.4rem 0.75rem;
  border: 1px solid transparent;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
  position: relative;
}

.game-item:hover {
  background: rgba(0, 255, 102, 0.05);
  border-color: var(--border2);
}

.game-item.selected {
  background: rgba(0, 255, 102, 0.1);
  border-color: transparent;
  color: var(--green3);
}


.game-title {
  font-size: 0.85rem;
  letter-spacing: 0.02em;
}

.game-launch {
  position: absolute;
  right: 0.75rem;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  color: var(--green3);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s, color 0.2s, text-shadow 0.2s;
}

.game-item.selected .game-launch {
  opacity: 1;
  pointer-events: auto;
}

.game-item.selected .game-launch:hover {
  color: var(--green);
  text-shadow: 0 0 8px var(--green);
}

.game-year {
  font-size: 0.7rem;
  opacity: 0.5;
  transition: opacity 0.2s;
}

.game-item.selected .game-year {
  opacity: 0;
}


.detail-name {
  font-family: var(--font-disp);
  font-size: 2.55rem;
  color: var(--amber);
  text-shadow: var(--glow-amb);
  letter-spacing: 0.06em;
  line-height: 1;
  margin-bottom: 0.5rem;
}

.detail-meta {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.detail-meta span {
  font-size: 0.9rem;
  letter-spacing: 0.12em;
  color: var(--text3);
}

.detail-meta strong {
  font-weight: normal;
  color: var(--green);
}

.detail-desc {
  font-size: 1rem;
  color: var(--text2);
  line-height: 1.6;
  letter-spacing: 0.02em;
  max-width: none;
  display: -webkit-box;
  -webkit-line-clamp: 12;
  line-clamp: 12;
  -webkit-box-orient: vertical;
  overflow-y: auto;
  padding-right: 10px;
}

.detail-desc::-webkit-scrollbar { width: 3px; }
.detail-desc::-webkit-scrollbar-track { background: transparent; }
.detail-desc::-webkit-scrollbar-thumb { background: var(--border2); }

.core-badge {
  display: inline-block;
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  padding: 2px 8px;
  background: rgba(0,255,136,0.08);
  border: 1px solid var(--green3);
  color: var(--green2);
  margin-right: 6px;
  margin-top: 6px;
}

/* === GRID === */
.section-label {
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  color: var(--text3);
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border);
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 10px;
}

.g-card {
  background: var(--card-bg);
  border: 1px solid var(--card-bdr);
  padding: 0.75rem;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
  display: flex;
  align-items: center;
  gap: 10px;
}

.g-card:hover {
  border-color: var(--green3);
  background: #0f1f17;
}

.g-card.active {
  border-color: var(--amber2);
  background: #1a1200;
}

.g-thumb {
  width: 36px;
  height: 36px;
  flex: 0 0 36px;
  border: 1px solid var(--border);
  background: #060c08;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.g-abbr {
  font-family: var(--font-crt);
  font-size: 1.4rem;
  color: var(--green3);
  line-height: 1;
}


.g-name {
  font-size: 0.9rem;
  letter-spacing: 0.04em;
  color: var(--text);
  line-height: 1.3;
}
.g-era { font-size: 0.8rem; color: var(--text3); }

.g-card.hidden { display: none; }

/* === FOOTER === */


/* === ANIMATIONS === */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.c-card, .g-card {
  animation: fadeInUp 0.3s ease both;
}

/* === FOOTER === */
.site-footer {
  background: var(--bg2);
  padding: 0.8rem 2rem;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}

.footer-block {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.beta-badge {
  font-family: var(--font-mono);
  font-size: 0.96rem;
  font-weight: bold;
  letter-spacing: 0.2em;
  color: var(--bg);
  background: var(--amber);
  padding: 2px 6px;
  clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
}

.footer-muted {
  font-family: var(--font-mono);
  font-size: 0.96rem;
  color: var(--border2);
  letter-spacing: 0.05em;
}

.footer-label {
  font-family: var(--font-mono);
  font-size: 0.88rem;
  letter-spacing: 0.2em;
  color: var(--border2);
}

.key-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
}

.key-item {
  font-family: var(--font-mono);
  font-size: 0.93rem;
  color: var(--border2);
  display: flex;
  align-items: center;
  gap: 0.3rem;
}

kbd {
  font-family: var(--font-mono);
  font-size: 0.88rem;
  color: var(--green3);
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-bottom: 3px solid var(--border2);
  border-radius: 3px;
  padding: 1px 7px 2px;
  box-shadow: 0 2px 0 rgba(0,0,0,0.4);
}

.footer-github {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: var(--border2);
  text-decoration: none;
  font-family: var(--font-mono);
  font-size: 0.96rem;
  letter-spacing: 0.1em;
  transition: color 0.2s;
}

.footer-github:hover {
  color: var(--green3);
}

/* === SCROLLBAR === */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border2); }

.game-list::-webkit-scrollbar { width: 1px; }
.game-list::-webkit-scrollbar-track { background: transparent; }
.game-list::-webkit-scrollbar-thumb { background: rgba(0, 136, 68, 0.3); }
.game-list::-webkit-scrollbar-thumb:hover { background: rgba(0, 136, 68, 0.7); }
.game-list { scrollbar-width: thin; scrollbar-color: rgba(0,136,68,0.3) transparent; }
::-webkit-scrollbar-thumb:hover { background: var(--green3); }


/* === RESPONSIVE === */
@media (max-width: 768px) {
  main { padding: 1rem; }
  header { padding: 1rem 1rem 0; }
  .logo { font-size: 2.6rem; }
  .c-card { flex: 0 0 140px; }
  .nav-left { left: 0; }
  .nav-right { right: 0; }
  .detail-img { flex: 0 0 90px; height: 90px; }
  .detail-name { font-size: 2.1rem; }
  .controls { gap: 1rem; }
  #search { width: 160px; }
  
  .detail-inner {
    grid-template-columns: 1fr;
    height: auto;
    max-height: 80vh;
    overflow-y: auto;
  }
  
  .detail-games {
    border-left: none;
    border-top: 1px solid var(--border2);
    padding-left: 0;
    padding-top: 1.5rem;
    height: 300px;
  }
}
/* ==========================================================================
   GAME MODE: EMULATOR OVERLAY & BOOT SCREEN
   ========================================================================== */

#emulator-overlay {
  position: fixed;
  inset: 0;
  background: #000;
  z-index: 9999;
  display: none; /* Ativado via JS */
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

#emulator-container {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 1s ease;
}

#emulator-container.visible {
  opacity: 1;
}

/* --- BOOT SCREEN & TV NOISE --- */
.boot-screen {
  position: absolute;
  inset: 0;
  background: #030303;
  z-index: 10001;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: opacity 0.8s ease-out;
}

.boot-noise {
  position: absolute;
  inset: -20%; /* Maior para permitir o tremor sem bordas brancas */
  background: 
    repeating-radial-gradient(#fff 0 0.0001%, #222 0 0.0002%) 50% 0/2500px 2500px,
    repeating-conic-gradient(#fff 0 0.0001%, #111 0 0.0002%) 50% 50%/2500px 2500px;
  background-blend-mode: overlay;
  opacity: 0.25; /* Mais intenso como na foto */
  animation: tv-snow 0.1s infinite;
  pointer-events: none;
  filter: contrast(200%) brightness(150%);
}

@keyframes tv-snow {
  0% { transform: translate(0,0) scale(1.1); }
  25% { transform: translate(-1%, 1%) scale(1.1); }
  50% { transform: translate(1%, -1%) scale(1.1); }
  75% { transform: translate(-1%, -1%) scale(1.1); }
  100% { transform: translate(1%, 1%) scale(1.1); }
}

@keyframes flicker {
  0% { opacity: 0.1; }
  100% { opacity: 0.15; }
}

.boot-logo {
  position: relative;
  z-index: 1000;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 10vw; /* Grande, mas equilibrado */
  font-weight: 700;
  line-height: 0.8;
  color: var(--text);
  text-align: center;
  letter-spacing: -0.02em;
  animation: boot-glow 2s ease-in-out infinite;
  filter: drop-shadow(0 0 50px var(--green3));
  display: flex;
  flex-direction: column;
  align-items: center;
}



@keyframes boot-glow {
  0%, 100% { text-shadow: 0 0 10px rgba(0, 255, 65, 0); opacity: 0.8; }
  50% { text-shadow: 0 0 30px rgba(0, 255, 65, 0.4); opacity: 1; }
}

/* --- EXIT BUTTON --- */
.exit-emulator {
  position: absolute;
  top: 20px;
  right: 20px;
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 8px 15px;
  font-family: var(--font-mono);
  font-weight: 900;
  font-size: 0.75rem; /* Aumentado ligeiramente */
  letter-spacing: 0.15em;
  cursor: pointer;
  z-index: 10010;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.3s;
  opacity: 0;
  background: rgba(0, 0, 0, 0.85); /* Fundo um pouco mais opaco */
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(6px); /* Blur mais forte */
  text-shadow: 0 0 5px rgba(255,255,255,0.3);
}

#emulator-overlay:hover .exit-emulator {
  opacity: 1;
}

.exit-emulator:hover {
  background: var(--green3);
  border-color: var(--green3);
  color: #000;
  box-shadow: 0 0 15px rgba(0, 255, 102, 0.4);
}
